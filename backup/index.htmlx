        <section id="team" class="team-section pt-120 pb-120">
            <div class="container">
                <div class="row">
                    <div class="col-xl-8 col-lg-8 mx-auto">
                        <div class="section-title text-center mb-55">
                            <h2 class="mb-20 wow fadeInUp" data-wow-delay=".2s">Meet the Team</h2>
                            <p class="wow fadeInUp" data-wow-delay=".4s">A small, dedicated team focused on research, portfolio construction and risk management. Below are our portfolio managers and analysts who build and monitor our strategies.</p>
                        </div>
                    </div>
                </div>
                <div class="row justify-content-center">
                    <div class="col-xl-4 col-lg-4 col-md-6">
                        <div class="single-team text-center mb-30 wow fadeInUp" data-wow-delay=".2s">
