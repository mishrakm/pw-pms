                    <div class="col-xl-4 col-lg-4 col-md-6">
                        <div class="single-team text-center mb-30 wow fadeInUp" data-wow-delay=".4s">
                            <div class="team-thumb mb-20">
                                <img src="assets/img/about-img.svg" alt="Team member" style="max-width:180px;border-radius:50%;">
                            </div>
                            <div class="team-content">
                                <h5>Priya Sharma</h5>
                                <p class="text-muted">Quant Analyst</p>
                                <p class="mb-0">Builds and validates signals, backtests investment rules and ensures model robustness.</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-xl-4 col-lg-4 col-md-6">
                        <div class="single-team text-center mb-30 wow fadeInUp" data-wow-delay=".6s">
                            <div class="team-thumb mb-20">
                                <img src="assets/img/feature-1.svg" alt="Team member" style="max-width:180px;border-radius:50%;">
                            </div>
                            <div class="team-content">
